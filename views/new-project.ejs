<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create new task</title>
    <link rel="stylesheet" href="/new-project.css">
</head>

<body>
    <div class="header">
        <a href="/projects"><img src="/main.png" alt=""></a>
        <ul>
            <li><a href="/projects/new">Add Project</a></li>
