<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Project</title>
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="/css/update-project.css" />
    <link rel="stylesheet" href="/css/modal.css">
</head>

<body>

    <!-- NAV -->
    <nav>
        <div class="nav-logo">
            <a href="/projects"><img src="/images/main.png" alt=""></a>
            <!-- <svg viewBox="0 0 40 40" fill="none" stroke="#1a9e9e" stroke-width="1.6" stroke-linecap="round"
                stroke-linejoin="round">
                <circle cx="20" cy="15" r="7" />
                <path d="M6 36c0-7.732 6.268-14 14-14s14 6.268 14 14" />
                <path d="M14 10 Q20 4 26 10" />
            </svg> -->
        </div>
        <div class="nav-links">
            <a href="/new-project">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                    <line x1="8" y1="2" x2="8" y2="14" />
                    <line x1="2" y1="8" x2="14" y2="8" />
                </svg>
                Add Project
            </a>
            <a href="/edit-profile">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
                    stroke-linejoin="round">
                    <circle cx="8" cy="8" r="3" />
                    <path
                        d="M8 1v2M8 13v2M1 8h2M13 8h2M3.22 3.22l1.42 1.42M11.36 11.36l1.42 1.42M3.22 12.78l1.42-1.42M11.36 4.64l1.42-1.42" />
                </svg>
                Edit Profile
            </a>
            <a href="/auth/logout">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
                    stroke-linejoin="round">
                    <path d="M10 8H2m0 0 3-3M2 8l3 3M14 4v8" />
                </svg>
                Log Out
            </a>
        </div>
    </nav>

    <!-- LAYOUT -->
    <div class="layout">

        <!-- MAIN -->
        <div class="main">

            <h1>Edit Project</h1>
            <div class="created-by">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                    stroke-linejoin="round">
                    <path d="M11 10.5a1 1 0 0 1 1 1v.5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-.5a1 1 0 0 1 1-1" />
                    <path d="M9.5 4.5 11 6l-5 5H4.5V9.5l5-5z" />
                </svg>
                Created by: toto@gmail.com
            </div>

            <!-- Name -->
            <div class="form-row">
                <label for="projName">Name</label>
                <div class="input-btn-row">
                    <div class="name-input-wrap">
                        <input type="text" id="projName" value="New Project!!" placeholder="Project name" />
                    </div>
                    <button class="btn-gray" id="updateNameBtn">Update Name</button>
                </div>
            </div>

            <!-- Description -->
            <div class="form-row">
                <label for="projDesc">Description</label>
                <div class="input-btn-row">
                    <div class="desc-input-wrap">
                        <textarea id="projDesc" placeholder="Description"></textarea>
                    </div>
                    <button class="btn-gray desc-btn" id="updateDescBtn">Update
                        Description</button>
                </div>
            </div>

            <!-- Add Member -->
            <div class="form-row">
                <label>Add Member (email)</label>
                <div class="member-row">
                    <input type="email" class="member-input" id="memberEmail" placeholder="" />
                    <label class="toggle-wrap">
                        <span class="toggle">
                            <input type="checkbox" id="adminToggle" />
                            <span class="toggle-slider"></span>
                        </span>
                        Admin
                    </label>
                    <button class="btn-amber" onclick="addMember()" title="Add member">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                            stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <line x1="19" y1="8" x2="19" y2="14" />
                            <line x1="16" y1="11" x2="22" y2="11" />
                        </svg>
                    </button>
                </div>
            </div>

        </div>

        <!-- SIDEBAR -->
        <div class="sidebar">
            <button class="btn-overview">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                    stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                    <circle cx="12" cy="12" r="3" />
                </svg>
                Project Overview
            </button>
            <button class="btn-delete-project" id="delBtn" onclick="openModal(this.dataset.id)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
                    stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6" />
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                    <path d="M10 11v6M14 11v6" />
                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
                </svg>
                Delete Project
            </button>
        </div>

    </div>

    <script>

        function addMember() {
            const email = document.getElementById('memberEmail').value.trim();
            const isAdmin = document.getElementById('adminToggle').checked;
            if (!email) { alert('Please enter an email address.'); return; }
            alert('Member added: ' + email + (isAdmin ? ' (Admin)' : ''));
            document.getElementById('memberEmail').value = '';
            document.getElementById('adminToggle').checked = false;
        }



        const pathParts = window.location.pathname.split('/');
        const projectId = pathParts[pathParts.length - 1];
        console.log("Projet IDI ------ " + projectId);

        async function loadProject(projectId) {
            try {
                const res = await fetch(`/projects/${projectId}`);
                console.log("Fetch response object:", res); // здесь видно status, headers и т.д.

                if (!res.ok) throw new Error(`HTTP status ${res.status}`);

                const project = await res.json();
                console.log("Project JSON data:", project);
                // ✅ здесь видно весь объект проекта
                document.getElementById('projName').value = project.name;
                document.getElementById('projDesc').value = project.description;
                const delBtn = document.getElementById('delBtn');
                delBtn.dataset.id = project.id;  // ✅ присваиваем data-id
                return project;
            } catch (err) {
                console.error("Error loading project:", err);
            }
        }

        async function deleteProject(projectId) {
            try {
                const res = await fetch(`/projects/del/${projectId}`, {
                    method: 'DELETE'
                });
                if (!res.ok) {
                    alert("It is impossible to delete someone else's project.");
                    return;
                }

            } catch (err) {
                alert("Network error");
            }
        };

        async function updateProject(projectId) {
            try {
                const res = await fetch(`/projects/update/${projectId}`, {
                    method: 'UPDATE'
                });
                if (!res.ok) {
                    alert("It is impossible to update someone else's project.");
                    return;
                }

            } catch (err) {
                alert("Network error");
            }

        }


        const updateNameBtn = document.getElementById('updateNameBtn');
        const updateDescBtn = document.getElementById('updateDescBtn');
        const projNameInput = document.getElementById('projName');
        const projDescInput = document.getElementById('projDesc');
        const delBtn = document.getElementById('delBtn'); // dataset.id = projectId

        // Обновление только Name
        updateNameBtn.addEventListener('click', async () => {
            const projectId = delBtn.dataset.id;
            const name = projNameInput.value.trim();
            if (!name) return alert("Name cannot be empty");

            await updateProject(projectId, { name }); // передаем только name
        });

        // Обновление только Description
        updateDescBtn.addEventListener('click', async () => {
            const projectId = delBtn.dataset.id;
            const description = projDescInput.value.trim();

            await updateProject(projectId, { description }); // передаем только description
        });


        async function updateProject(projectId, data) {
            try {
                const res = await fetch(`/projects/update/${projectId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                });

                const result = await res.json();

                if (!res.ok) {
                    alert(result.error || "Update failed");
                    return false;
                }

                alert("Update successful!");
                return true;
            } catch (err) {
                console.error(err);
                alert("Network error");
                return false;
            }
        }
        // Вызов при загрузке страницы
        window.addEventListener('DOMContentLoaded', async () => {
            const project = await loadProject(projectId);
        });
    </script>

    <div id="modal" class="modal">
        <div class="modal-content">
            <p>You want delete this product ?</p>
            <div class="modal-actions">
                <button id="confirmBtnForUpdate">Delete</button>
                <button onclick="closeModal()">Cancel</button>
            </div>
        </div>
    </div>
</body>
<script src="/js/modal.js"></script>

</html>