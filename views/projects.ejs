<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Basecamp Lite</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/projects">🚀 Basecamp Clone</a>
            <div class="d-flex align-items-center text-white">
                <% if (isAdmin) { %><span class="badge bg-danger me-3">Admin</span><% } %>
                <a href="/logout" class="btn btn-outline-light btn-sm">Выйти</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="row mb-4">
            <div class="col-md-8 mx-auto">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Создать проект</h5>
                        <form action="/projects" method="POST" class="d-flex gap-2">
                            <input type="text" name="title" class="form-control" placeholder="Название..." required>
                            <button type="submit" class="btn btn-primary">Создать</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8 mx-auto">
                <h3>Мои проекты</h3>
                <% projects.forEach(project => { %>
                    <div class="card mb-3 shadow-sm border-0">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-0"><a href="/projects/<%= project.id %>" class="text-decoration-none text-dark"><%= project.title %></a></h5>
                                <small class="text-muted">Задач: <%= project.tasks.length %></small>
                            </div>
                            <div class="btn-group">
                                <a href="/projects/<%= project.id %>/edit" class="btn btn-sm btn-outline-secondary">✎</a>
                                <form action="/projects/<%= project.id %>/delete" method="POST" onsubmit="return confirm('Удалить проект?')">
                                    <button class="btn btn-sm btn-outline-danger ms-1">🗑</button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>
</body>
</html>